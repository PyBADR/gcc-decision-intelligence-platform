# ============================================================================
# Impact Observatory | مرصد الأثر — Environment Configuration
# ============================================================================
# Copy to .env: cp .env.example .env
# Production: set all required values, never commit .env

# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development                         # development | production
DEBUG=false
LOG_LEVEL=info

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gcc_intelligence
POSTGRES_USER=gcc_admin
POSTGRES_PASSWORD=changeme

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ─────────────────────────────────────────────────────────────
# Empty = dev mode (no auth). Production: openssl rand -hex 32
API_KEY=
JWT_SECRET_KEY=io-dev-secret-change-in-prod-2026

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://deevo-sim.vercel.app

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CESIUM_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Real-time data feeds (optional) ─────────────────────────────────────────
ACLED_API_KEY=
ACLED_API_EMAIL=
AISSTREAM_API_KEY=
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
FEED_REFRESH_MINUTES=15

# ── Map & Geospatial tokens (optional) ──────────────────────────────────────
CESIUM_ION_TOKEN=
MAPBOX_TOKEN=

# ── Slack notifications (optional) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Deployment monitoring (optional) ────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ── GitHub connector (optional) ─────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO_OWNER=PyBADR
GITHUB_REPO_NAME=gcc-decision-intelligence-platform
